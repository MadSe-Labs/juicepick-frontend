# ========================================
# JuicePick Environment Variables
# ========================================
# 이 파일을 복사하여 .env.local 또는 .env.development 생성
# 실제 값으로 교체하세요

# ----------------------------------------
# Environment
# ----------------------------------------
NODE_ENV=development

# ----------------------------------------
# NextAuth.js 설정 (기존 - 현재 미사용)
# ----------------------------------------
# NEXTAUTH_SECRET=your-secret-key-here
# NEXTAUTH_URL=http://localhost:3000

# ----------------------------------------
# Supabase Configuration
# ----------------------------------------
# 🔧 로컬 개발 환경 (supabase start 사용 시)
# NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0

# 🌐 실제 Supabase 프로젝트 (팀 협업 시)
# Supabase Dashboard → Settings → API에서 확인
NEXT_PUBLIC_SUPABASE_URL=your-project-url-here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ⚠️ Service Role Key (서버 사이드 전용 - 브라우저 노출 금지!)
# 현재 프로젝트에서는 사용하지 않지만 추후 서버 액션용
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ----------------------------------------
# Application Settings
# ----------------------------------------
NEXT_PUBLIC_APP_NAME=JuicePick
NEXT_PUBLIC_APP_VERSION=1.0.0

# ----------------------------------------
# Development Tools (개발 환경에서만)
# ----------------------------------------
# 디버그 모드 활성화
NEXT_PUBLIC_ENABLE_DEBUG=false

# React Query DevTools 표시
NEXT_PUBLIC_SHOW_QUERY_DEVTOOLS=false

# ----------------------------------------
# 📝 설정 가이드
# ----------------------------------------
# 
# 1️⃣ 로컬 Supabase 사용 (추천 - 개발용)
#    - supabase start 실행
#    - NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
#    - 로컬 DB 사용, 팀원들과 독립적으로 개발 가능
#
# 2️⃣ 실제 Supabase 프로젝트 사용 (팀 협업 시)
#    - 팀 리더에게 Project URL과 Anon Key 받기
#    - NEXT_PUBLIC_SUPABASE_URL과 ANON_KEY 입력
#    - 팀원들과 같은 DB 공유
#
# 3️⃣ 환경별 파일 (선택사항)
#    - .env.development (개발)
#    - .env.production (프로덕션)
#    - .env.local (로컬 - Git 제외, 최우선 적용)
#
# ----------------------------------------

